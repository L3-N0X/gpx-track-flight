{
    "name": "gpx-track-flight",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "concurrently -n \"frontend,backend\" -c \"cyan,magenta\" \"bun run dev:frontend\" \"bun run dev:backend\"",
        "dev:frontend": "bunx vite",
        "dev:backend": "bun --hot run server.ts",
        "build": "tsc -b && bunx --bun vite build",
        "lint": "eslint . --cache --ext .ts,.tsx",
        "preview": "vite preview",
        "format": "bunx prettier --write ."
    },
    "dependencies": {
        "@prisma/client": "^7.8.0",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-navigation-menu": "^1.2.14",
        "@radix-ui/react-slot": "^1.2.4",
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.5.0",
        "@tailwindcss/vite": "^4.2.1",
        "@types/three": "0.170.0",
        "bun": "^1.3.10",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.577.0",
        "prisma-adapter-bun-sqlite": "^0.8.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-router": "^7.13.1",
        "react-router-dom": "^7.13.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "three": "0.170.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "^1.3.10",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "eslint": "^10.0.3",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "prisma": "^7.8.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^8.0.0"
    }
}
